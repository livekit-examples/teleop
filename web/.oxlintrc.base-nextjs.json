{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["./base.oxlintrc.json"],
  "plugins": ["typescript", "unicorn", "react", "nextjs", "jsx-a11y", "import"],
  "ignorePatterns": [
    "**/gen/",
    "**/dist/",
    "storybook-static/**",
    ".next/**",
    "build/**",
    "next-env.d.ts"
  ],
  "rules": {
    "import/no-anonymous-default-export": "warn"
  }
}
